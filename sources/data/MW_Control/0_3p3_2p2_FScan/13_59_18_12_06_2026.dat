#<scrname>0_3p3_2p2_FScan</scrname>
#<sourcecode>double pi = 3.14159265359;\n\n\ndouble pdq_ttl = 0;\n\n\n\n\n\n\ndouble dds_b1 = 1;\ndouble dds_tickle = 0;\ndouble dds_b3 = 2;\ndouble dds_mw = 4;\ndouble dds_strobo= 5;\n\n\ndouble upload_status =19;\ndouble counter_trigger = 18;\ndouble counter_gate = 16;\ndouble dds_test = 15;\ndouble pdq_trigger = 14;\ndouble sw_lowRF = 21;\ndouble counter_gate_2 = 88;\n\n\ndouble sw_tickle = 12;\ndouble sw_mw = 11;\n\n\ndouble b3 = 20;\ndouble r2 = 10;\ndouble r1 = 9;\ndouble b1 = 7;\ndouble bdd = 6;\ndouble bd = 5;\ndouble bdx  = 3;\ndouble rd = 1;\ndouble rp = 0;\ndouble r3 = 17;\n\n\ndouble ctr_bd_b3 = 0;\ndouble ctr_b1_r2 = 1;\n\ndouble ax_b3_y = 0;\ndouble ax_b3_x = 1;\ndouble ax_bd_y = 2;\ndouble ax_bd_x = 3;\n\ndouble ax_b1_x = 0;\ndouble ax_b1_y = 1;\ndouble ax_r2_x = 2;\ndouble ax_r2_y = 3;\n\n\ndouble ax_r2_V = 0;\ndouble ax_r2_H = 1;\n\ndouble ax_b1_V = 2;\ndouble ax_b1_H = 3;\n\nvoid set_dds(ddsname,frequency,phase,power){\n\tif(ddsname == dds_b1){\t\t\t\n\t\t\tdac_select(0);\t\t\t\t\n\t\t\tdac_voltage(power);\t\n\t\t\tdds_select(0);\n\t\t\tdds_frequency((frequency/8.) MHz);\n\t\t\tdds_phase(phase);\n\t\t\tdds_update();\t\n\t}\n\tif(ddsname == dds_tickle){\n\n\n\t\t\tdds_select(1);\n\t\t\tdds_frequency(frequency MHz);\n\t\t\tdds_phase(phase);\n\t\t\tdds_update();\t\n\t}\n\tif(ddsname == dds_b3){\n\t\t\tdac_select(2);\t\t\t\n\t\t\tdac_voltage(power);\t\n\t\t\tdds_select(2);\t\t\t\n\n\t\t\tdds_frequency((frequency/8) MHz);\n\t\t\tdds_phase(phase);\n\t\t\tdds_update();\t\n\t}\n\n\n\n\n\n\n\n\n\n\tif(ddsname == dds_mw){\n\n\t\t\tdac_select(0);\t\t\t\n\t\t\tdac_voltage(0.54);//0.54\t\n\t\t\tdds_select(0);\t\t\n\t\t\tdds_frequency((frequency/8) MHz);\n\t\t\tdds_phase(phase);\n\t\t\tdds_update();\n\t}\n\n\tif(ddsname == dds_strobo){\n\n\t\t\tdac_select(0);\t\t\t\n\t\t\tdac_voltage(power);\n\t\t\tdds_select(0);\t\t\n\t\t\tdds_frequency((frequency/8) MHz);\n\t\t\tdds_phase(phase);\n\t\t\tdds_update();\n\t}\nsleep(3 us);//very important for SBC, do not delet, otherwise the contrast is only half for RSB flops. (F.H. 2024-08-07)\n}\n\nvoid turn(ttlname,status){\n\tif(ttlname == bd){\t\t\t\tttl(1,status);}\n\tif(ttlname == bdd){\t\t\t\tttl(2,status);}\n\tif(ttlname == b1){\t\t\t\t\tttl(3, status);}\t\t\t\n\tif(ttlname == upload_status){\tttl(4,status);}\n\tif(ttlname == rp){\t\t\t\t\tttl(5, status);}\n\tif(ttlname == rd){\t\t\t\t\tttl(6, status);}\n\tif(ttlname == counter_trigger){\tttl(7,status);}\n\tif(ttlname == b3){\t\t\t\t\tttl(8,status);}\t\t\t\n\n\tif(ttlname == bdx){\t\t\t\tttl(10,status);}\n\tif(ttlname == r1){\t\t\t\t\tttl(11,status);}\n\tif(ttlname == r2){\t\t\t\t\tttl(12,status);}\n\tif(ttlname == sw_mw){\n\t\tif(status == 1){\t\t\t\tttl(14,0);}\n\t\tif(status == 0){\t\t\t\tttl(14,1);}\n\t}\n\tif(ttlname == sw_lowRF){\t\tttl(13,status);}\n\n\n\n\n\n\tif(ttlname == counter_gate_2){\n\t\tif(status == 1){\t\t\t\tttl(9,0);}\n\t\tif(status == 0){\t\t\t\tttl(9,1);}\t\t\t\t\t\t\n\t}\n\tif(ttlname == counter_gate){\n\t\tif(status == 1){\t\t\t\tttl(15,0);}\n\t\tif(status == 0){\t\t\t\tttl(15,1);}\t\t\t\t\t\t\n\t}\n}\n\nvoid turn_all_off(){\n\n\tturn(sw_tickle,\t\t0); \n\tturn(sw_mw,\t\t\t0);\n\tturn(b3,\t\t\t\t0);\n\tturn(r2,\t\t\t\t0);\n\tturn(r1,\t\t\t\t0);\n\tturn(b1,\t\t\t\t0);\n\tturn(bdd,\t\t\t\t0);\n\tturn(bd,\t\t\t\t0);\n\tturn(bdx,\t\t\t\t0);\n\tturn(rd,\t\t\t\t0);\n\tturn(rp,\t\t\t\t0);\n\n\n} \n\n\nvoid init_dac_dds(){\n\n\tdac_select(0);\n\tdac_voltage(0.600);\n\tdac_select(1);\n\tdac_voltage(0.000);\n\n\n\tdac_select(3);\n\tdac_voltage(0.600);\n\n\tdds_select(0);\n\tdds_frequency(220. MHz);\n\tdds_phase(0.);\n\tdds_update();\t\n\tdds_select(1);\n\tdds_frequency(220. MHz);\n\tdds_phase(0.);\n\tdds_update();\t\n\n\n\n\n\tdds_select(3);\n\tdds_frequency(220. MHz);\n\tdds_phase(0.);\n\tdds_update();\t\n}\n\nvoid pulse(ttlname,length){\n\tturn(ttlname, 1);\n\tsleep(length us);\n\tturn(ttlname, 0);\n}\n\nvoid init(){\n\tturn(upload_status,1);\n\tturn(counter_trigger,0);\n\tturn(counter_gate,0);\n\tturn(counter_gate_2,0);\n\tinit_dac_dds();\t\n\tturn_all_off();\n}\n\nvoid cooling_on(){\n\tturn(bdd, 1);\n\tif(bd_always_on == 1){\n\t\tturn(bd, 1);//To reduce the darkening of the ions (binding with H), we set the value from formally 1 to 0.\n\t}\n\tif(bd_always_on == 0){\n\t\tturn(bd, 0);//To reduce the darkening of the ions (binding with H), we set the value from formally 1 to 0.\n\t}\n}\n\nvoid cooling_off(){\n\tturn(bd, 0);\n\tturn(bdd, 0);\n\tturn(rd, 0);\n\tturn(rp, 0);\n}\n\nvoid experiment_init(){\n\tturn_all_off();\n\n\n\ttrigger(1);\n\n\n}\n\nvoid cool(t_bdd_cool_c, t_bd_cool_c,t_rd_cool_c){\n\n\tif(do_RF_lock==1){\n\t\tRF_lock_pulse( t_lock_RF);\n\t}\n\n\tturn_all_off();\n\tturn(bdd, 1);\n\tturn(bd, 1);\n\tturn(rd,1);\n\tturn(rp,1);\n\tsleep(t_bdd_cool_c us);\n\tturn(bdd, 0);\n\tsleep(t_bd_cool_c us);\n\tturn(bd, 0);\n\tsleep(t_rd_cool_c us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n}\n\nvoid det_ct2(){\n\tif(detect_ct2 == 1){\n\t\tsleep(1 ms); \n\t\tcool(t_bdd_cool,t_bd_cool,t_rd_cool);\n\t\tbeam_detect_ct2(t_det, bdx);\n\t}\n}\n\nvoid cool_without_BDD(t_bd_cool_c,t_rd_cool_c){\n\tturn_all_off();\n\tturn(bd, 1);\n\tturn(rd,1);\n\tturn(rp,1);\n\tsleep(t_bd_cool_c us);\n\tturn(bd, 0);\n\tsleep(t_rd_cool_c us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n}\n\nvoid tickle(fr_tickle_c,t_tickle_c){\n\tset_dds(dds_tickle,fr_tickle_c,0.,0.);\n\tturn(sw_tickle,1);\n\tsleep(t_tickle_c us);\n\tturn(sw_tickle,0);\n}\n\nvoid reorder(pdq_reorder_profile_c,t_shift_reorder_c,t_cool_reorder_c){\n\tcool(t_bdd_cool,t_bd_cool,t_rd_cool);\n\tcooling_on();\n\tpdq_step_to(pdq_reorder_profile_c, 1.0 us, 2);\n\tsleep(t_cool_reorder_c us);\t\n\tpdq_step_to(pdq_init_profile, t_shift_reorder_c us,2);\n\tcooling_off();\n}\n\nvoid unorder(pdq_reorder_profile_c,t_shift_reorder_c,t_cool_reorder_c){\n\tcool(t_bdd_cool,t_bd_cool,t_rd_cool);\n\n\tpdq_step_to(pdq_reorder_profile_c, 1.0 us, 2);\n\tsleep(t_cool_reorder_c us);\t\n\tpdq_step_to(pdq_init_profile, t_shift_reorder_c us,2);\n\tcooling_off();\n}\n\nvoid beam_detect(t_detect, beam){\n\tturn_all_off();\n\tturn(beam,1);\n\tsleep(2 us);\n\tturn(counter_gate,1);\n\tsleep(t_detect us); \n\tturn(counter_gate,0);\n\tturn(beam,0);\n}\n\nvoid short_detect(t_detect){\n\tturn(counter_gate,1);\n\tsleep(t_detect us); \n\tturn(counter_gate,0);\n}\n\nvoid short_detect_ct2(t_detect){\n\tturn(counter_gate_2,1);\n\tsleep(t_detect us); \n\tturn(counter_gate_2,0);\n}\n\nvoid beam_detect_ct2(t_detect, beam){\n\tturn_all_off();\n\tturn(beam,1);\n\tsleep(2 us);\n\tturn(counter_gate_2,1);\n\tsleep(t_detect us); \n\tturn(counter_gate_2,0);\n\tturn(beam,0);\n}\n\nvoid read(){\n\tturn(counter_trigger,1);\n\tsleep(10 us);\n\ttrigger(0);\n\tturn(counter_trigger,0);\n\tcooling_on();\n}\n\nvoid close(){\n\tcooling_on();\n\tturn(upload_status,0);\n\tturn(counter_trigger,0);\n\tturn(counter_gate,0);\n\tturn(counter_gate_2,0);\n}\n\n\n\nvoid lock_pulse(beam_conf_lock,fr_delta_c, t_lock_c){\n\tif(beam_conf_lock == 0){\n\n\t\tset_dds(dds_b1, fr_mw_3p3_2p2+fr_delta_c, 0.0, 0.6);\n\t\t\n\t\tturn(b1, 1);\n\t\tturn(r1,1);\n\t\tsleep(1 us);\n\n\t\tttl_pdq(ch3p7, 0);\n\t\tsleep(t_lock_c us);\n\t\tttl_pdq(ch3p7, 1);\n\n\t\tturn(b1, 0);\n\t\tturn(r1,0);\n\n\t}\n\n\tif(beam_conf_lock == 5){\n\n\t\tset_dds(dds_b1, (fr_mw_3p3_2p2-10), 0.0, 0.6);\n\t\t\n\n\t\tturn(b3, 1);\n\t\tturn(r1,1);\n\t\tsleep(1 us);\n\n\t\tttl_pdq(ch3p7, 0);\n\t\tsleep(t_lock_c us);\n\t\tttl_pdq(ch3p7, 1);\n\n\t\tturn(b3, 0);\n\t\tturn(r1,0);\n\n\t}\n\tsleep(1 us);\n}\n\n\nvoid RF_lock_pulse( t_lock_c){\n\t\tttl_rf( 0);\n\t\tsleep(t_lock_c us);\n\t\tttl_rf(1);\n\tsleep(1 us);\n}\n\n\nvoid RPE_3p3_2p2_MW_CC(fr_delta, t_lock, t_ramsey, phs, vice_versa, do_lock){\n\tset_dds(dds_mw, fr_mw_3p3_2p2, 0.0, 0.0);\n\tset_dds(dds_b1, fr_mw_3p3_2p2+fr_delta, 0.0, pwr_b1);\n\t\n\tif(do_lock==1){\n\t\tlock_pulse(0,fr_delta, t_lock);\n\t}\n\n\tif(vice_versa==0){\n\t\tmwpulse(fr_mw_3p3_2p2,t_mw_3p3_2p2/2,0.);\n\t\tsleep(t_ramsey);\n\t\t rtpulse(0,fr_cc_3p3_2p2,t_cc_3p3_2p2/2,phs,pwr_b1,fr_r2, pwr_r2);\n\t}\n\tif(vice_versa==1){\n\t\t rtpulse(0,fr_cc_3p3_2p2,t_cc_3p3_2p2/2,0.0,pwr_b1,fr_r2, pwr_r2);\n\t\tsleep(t_ramsey);\n\t\tmwpulse(fr_mw_3p3_2p2,t_mw_3p3_2p2/2,phs*2);\t\n\t}\n}\t\n\n\n\n\n\nvoid tickle_pdq(shim_c, fr_c, t_c, u_c, phase_c, phase_reset_c)\n{\n\n\n\ttickle_pdq_pulse(shim_c, fr_c, t_c, u_c, phase_c, phase_reset_c,0);\n\n\n}\n\n\nvoid tickle_ultra_phase(fr_tickle_c,\tt_tickle_c,\tpwr_tickle_c,\tpwr_rf_tickle_c,\trf_tickle, phase)\n{\n\tif(rf_tickle == 1){\n\t\tset_dds(tickle,\tfr_tickle_c,\tphase,\tpwr_rf_tickle_c);\n\t\tpulse(sw_rf_tickle, \tt_tickle_c);\n\t}\n\tif(rf_tickle == 0){\n\t\tset_dds(tickle,\tfr_tickle_c,\tphase,\tpwr_tickle_c);\n\t\tpulse(sw_dc_tickle, \tt_tickle_c);\n\t}\n}\n\nvoid tickle_phase(fr_tickle_c,\tt_tickle_c,\tpwr_tickle_c,\tpwr_rf_tickle_c,\trf_tickle, phase)\n{\n\tif(rf_tickle == 1){\n\t\tset_dds(tickle,\tfr_tickle_c,\tphase,\tpwr_rf_tickle_c);\n\t\tpulse(sw_rf_tickle, \tt_tickle_c);\n\t}\n\tif(rf_tickle == 0){\n\t\tset_dds(tickle,\tfr_tickle_c,\tphase,\tpwr_tickle_c);\n\t\tpulse(sw_dc_tickle, \tt_tickle_c);\n\t}\n}\n\nvoid tickle_RF_via_DDS_PDQ_Coherent(dac_slct_c,  fr_DDS_c, t_tickle_DDS_c, pwr_DDS_c , phase_c)\n{\n\tttl(13,1);\n\tdac_select(dac_slct_c);\t\t\t\n\tdac_voltage(pwr_DDS_c);\t\n\tdds_select(dac_slct_c);\t\t\t\n\tdds_frequency(fr_DDS_c MHz);\n\tdds_phase(phase_c);\n\tdds_update();\n\tsleep((t_tickle_DDS_c-0.25) us);\n\tdac_select(dac_slct_c);\t\t\t\n\tdac_voltage(0.);\t\n\tdds_select(dac_slct_c);\t\t\t\n\tdds_frequency((0.0) MHz);\n\tdds_phase(0.0);\n\tdds_update();\n\tttl(13,0);\n}\n\nvoid tickle_RF_via_DDS_TTL_Off(dac_slct_c,  fr_DDS_c, t_tickle_DDS_c, pwr_DDS_c , phase_c)\n{\n\tdac_select(dac_slct_c);\t\t\t\n\tdac_voltage(pwr_DDS_c);\t\n\tdds_select(dac_slct_c);\t\t\t\n\tdds_frequency(-fr_DDS_c MHz);\n\tdds_phase(phase_c);\n\tdds_update();\n\tsleep((t_tickle_DDS_c-0.25) us);\n\tdac_select(dac_slct_c);\t\t\t\n\tdac_voltage(0.);\t\n\tdds_select(dac_slct_c);\t\t\t\n\tdds_frequency((0.0) MHz);\n\tdds_phase(0.0);\n\tdds_update();\n}\n\nvoid tickle_RF_via_DDS(dac_slct_c,  fr_DDS_c, t_tickle_DDS_c, pwr_DDS_c , phase_c)\n{\n\n\tdac_select(dac_slct_c);\t\t\t\n\tdac_voltage(pwr_DDS_c);\t\n\tdds_select(dac_slct_c);\t\t\t\n\tdds_frequency(fr_DDS_c MHz);\n\tdds_phase(phase_c);\n\tdds_update();\n\n\tttl(13,1);\n\tsleep(t_tickle_DDS_c us);\n\tttl(13,0);\n\n\n\n\n\n}\n\nvoid rtpulsehelper(bluebeam, redbeam, bluedds, bluefrequency, bluephase,  bluepower, reddds, redfrequency, redpower, status){\n\tif(status == 1){\n\t\tset_dds(dds_b1,\tbluefrequency, bluephase, bluepower);\n\n\t}\n\tturn(bluebeam, status);\n\tsleep(0.05 us); \n\tturn(redbeam, status);\n\tsleep(delay_Raman us);\n}\n\nvoid rtpulse(beam_conf, fr_raman, t_pulse, phase,power, red_fr, red_power){\n\tif(beam_conf == 0){\n\t\trtpulsehelper(b1, r1, dds_b1,  fr_raman, phase, power, dds_tickle, red_fr , red_power, 1);\n\t\tsleep(t_pulse us);\n\t\trtpulsehelper(b1, r1, dds_b1,  fr_raman, phase, power, dds_tickle, red_fr , red_power, 0);\n\t}\n\tif(beam_conf == 1){\n\t\trtpulsehelper(b1, r2, dds_b1,  fr_raman, phase, power, dds_tickle, red_fr , red_power, 1);\n\t\tsleep(t_pulse us);\n\t\trtpulsehelper(b1, r2, dds_b1,  fr_raman, phase, power, dds_tickle, red_fr , red_power, 0);\n\t}\n\tif(beam_conf == 2){\n\n\t\trtpulsehelper(b3, r2, dds_b1,  fr_raman, phase, power, dds_tickle, red_fr , red_power, 1);\n\t\tsleep(t_pulse us);\n\t\trtpulsehelper(b3, r2, dds_b1,  fr_raman, phase, power, dds_tickle, red_fr , red_power, 0);\n\t\t\n\t}\n\tif(beam_conf == 3){\n\t\trtpulsehelper(b1, r3, dds_b1,  fr_raman, phase, power, dds_mw, red_fr+1574.746715 , red_power, 1);\n\t\tsleep(t_pulse us);\n\t\trtpulsehelper(b1, r3, dds_b1,  fr_raman, phase, power, dds_mw, red_fr+1574.746715 , red_power, 0);\n\t}\n\tif(beam_conf == 4){\n\n\t\trtpulsehelper(b3, r3, dds_b1,  fr_raman, phase, power, dds_mw, red_fr+1574.746715 , red_power, 1);\n\t\tsleep(t_pulse us);\n\t\trtpulsehelper(b3, r3, dds_b1,  fr_raman, phase, power, dds_mw, red_fr+1574.746715 , red_power, 0);\n\t}\n\tif