TL_off(fr_rsb1_c, t_oc_c, conf){\n\tif(conf == 5){\n\t\trtpulse_PDQ_coherent_TTL_off(conf, (fr_rsb1_c), t_oc_c, 0., pwr_b1_sbc, fr_r2, pwr_r2_sbc);\n\t}\n\tturn(rd, 1);\n\tturn(rp, 1);\n\tsleep(t_rd_sbc us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n}\n\nvoid sb_cool_block_PDQ_coherent_TTL_off(cool_Q, fr_raman_carrier, fr_raman_mode, fr_mode, t_pulse, beamconf, calc_Q){\n\tif(cool_Q == 1){\n\t\tif(t_pulse &gt; 0 ){\n\t\t\tif(calc_Q == 0){\n\t\t\t\tsb_cool_cycle_PDQ_coherent_TTL_off(fr_raman_mode, t_pulse, beamconf);\n\t\t\t}\n\t\t}\n\t\tif(t_pulse == 0){\n\t\t\tsleep(0);\n\t\t}\n\t}\n\tsleep(0);\n}\n\n\n\nvoid pdq_shuttle_to(target_profile, t_ramp, t_wait, special){\n\tpdq_step_to(target_profile, t_ramp us, special);\n\tsleep(t_wait us);\n}\n\nvoid pdq_single_pulse(select_shim, wvf_id, wvf_amp,wvf_offset){\n\tpdq_pulse(select_shim, wvf_id, wvf_amp, wvf_offset, 0, 0);\n\tsleep(1 us);\n}\n\nvoid tickle_pdq_pulse(shim_c, fr_c, t_c, u_c, phase_c, phase_reset_c, pulse_shape_c) {\n\n\n\tif(pulse_shape_c == 0){//rect 1 * t_tickle\n\t\tpdq_tickle_pulse(shim_c , fr_c MHz , u_c, t_c, phase_c, phase_reset_c, pulse_shape_c);\n\t\tsleep(t_c us);\n\t}\n\tif(pulse_shape_c == 1){//gauss 4 * t_tickle\n\t\tpdq_tickle_pulse(shim_c , fr_c MHz , u_c, t_c, phase_c, phase_reset_c, pulse_shape_c);\n\t\tsleep(4. * t_c*  us);\n\t}\n\tif(pulse_shape_c == 2){//sinc 26 * t_tickle\n\t\tpdq_tickle_pulse(shim_c , fr_c MHz , u_c, t_c, phase_c, phase_reset_c, pulse_shape_c);\n\t\tsleep(26. * t_c * us);\n\t}\n\n\n}\n\nvoid tickle_pdq_pulse_par(shim_c, fr_c, t_c, u_c, phase_c, phase_reset_c,A1,A2) {\n\n\tpdq_tickle_pulse_par(shim_c , fr_c MHz , u_c , t_c, phase_c, phase_reset_c,A1,A2);\n\tsleep(t_c us);\n\n}\n\nvoid tickle_pdq_offset(shim_c, fr_c, t_c, u_c, phase_c, phase_reset_c,offset_profile_c,profile_shim_c) {\n\tpdq_tickle_offset(shim_c , fr_c MHz , u_c , t_c, phase_c, phase_reset_c,offset_profile_c,profile_shim_c);\n\tsleep(t_c us);\n}\n\nvoid ttl_pdq(channel, status) {\n\tif(status == 0) {\n\n\t\tpdq_shuttle_to(EU_cool_PDQ_TTL_OFF, 1, 1, 0);\n\t}\n\tif(status == 1) {\n\n\t\tpdq_shuttle_to(EU_cool, 1, 1, 0);\n\t}\n\tsleep(5 us);\n}\n\nvoid ttl_rf(status) {\n\tif(status == 0) {\n\t\tpdq_shuttle_to(EU_cool_RF_TTL_OFF, 0.1, 0, 0);\n\t}\n\tif(status == 1) {\n\t\tpdq_shuttle_to(EU_cool, 0.1, 0, 0);\n\t}\n\tsleep(5 us);\n}\n\n\nvoid tickle_pdq_step(shim_c, fr_c, t_c ,u_c, phase_c, phase_reset_c,t_step_c,profile_c, special_c) {\n\tpdq_step_to(profile_c, t_step_c us, special_c);\n\tpdq_tickle_start(shim_c , fr_c MHz , u_c , phase_c, phase_reset_c);\n\tsleep(t_c us);\n\tpdq_tickle_stop();\n\tpdq_step_to(pdq_init_profile, t_step_c us, special_c);\n}\n\n\nvoid tickle_pdq_MDLTN_OFFST(shim_c, fr_c, t_c ,u_c, phase_c, phase_reset_c,t_step_c,profile_c, special_c) {\n\tpdq_step_to(profile_c, t_step_c us, special_c);\n\tpdq_tickle_start(shim_c , fr_c MHz , u_c , phase_c, phase_reset_c);\n\tpdq_tickle_start(shim_exc, fr_exc MHz, u_exc, .0, 2);\n\tsleep(t_c us);\n\tpdq_tickle_stop();\n\tpdq_step_to(pdq_init_profile, t_step_c us, special_c);\n}\nvoid pdq_osci_trigger(){\n\n\tttl(13,1);\n\tsleep(0.5 us);\n\tttl(13,0);\n}\n\nvoid pdq_osci_trigger_0(){\n\n\tttl(0,1);\n\tsleep(0.5 us);\n\tttl(0,0);\n}\nmain() {\ninit();\nloop(LOOPSP1){\n\texperiment_init();\t\n\tpdq_init(pdq_init_profile);\n\t\n\tif(reorder_Q == 1){\n\treorder(pdq_reorder_profile,t_shift_reorder,t_cool_reorder);\n\t}\t\n\t\n\n\tcool(t_bdd_cool,t_bd_cool,t_rd_cool);\n\tsb_cooling();\t\n\t\n\tmwpulse(fr_mw_3p3_2p2,t_mw_3p3_2p2,0.);\n\n\tbeam_detect(t_det, bdx);\n\tread();\n}\nclose();\n}</sourcecode>
