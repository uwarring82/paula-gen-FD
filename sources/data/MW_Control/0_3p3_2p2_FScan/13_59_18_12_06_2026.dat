age(0.);\t\n\t\t\tdds_select(2);\t\t\t\n\t\t\tdds_frequency((0.0) MHz);\n\t\t\tdds_phase(0.0);\n\t\t\tdds_update();\n\t\t\t}\n\t\t}\n\n\n\n\nvoid active_phase_grating(sel, fr_mw, N_strobo, DELTA_t, delta_t, phase, t_ramsey, pwr_mw, N_max){\n\n\n\n\tif (sel==1){\n\n\t\tset_dds(dds_strobo,fr_mw, phase, pwr_mw);\n\n\t\tsleep((t_ramsey + (N_max - N_strobo)/2 * DELTA_t) us);\n\n\t\tfor(double i= 1; i &lt; (N_strobo)/2.+0.5; i = i + 1){\n\t\t\tsleep((DELTA_t -delta_t) us);\n\t\t\tturn(sw_mw, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(sw_mw, 0);\n\t\t}\n\t}\n\n\tif (sel==0){\n\n\t\tset_dds(dds_mw,fr_mw, phase, 0.54);\n\n\t\tsleep((t_ramsey + (N_max/2 * DELTA_t) - delta_t) us);\n\n\n\n\t\tfor(double i= 1; i &lt; 1.5; i = i + 1){\n\t\t\tturn(sw_mw, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(sw_mw, 0);\n\t\t}\n\t}\n\n}\n\n\nvoid active_phase_grating_Laser_old(beam1, beam2, sel, frequency, N_strobo, DELTA_t, delta_t, phase, t_ramsey, pwr, N_max){\n\n\n\n\n\n\n\n\n\n\n\n\n\n\t\n\tif (sel==1){\n\n\t\tset_dds(dds_strobo,frequency, phase, pwr);\n\t\tturn(beam1, 1);\n\n\t\tsleep((t_ramsey + (N_max - N_strobo)/2 * DELTA_t) us);\n\n\t\t\n\t\tfor(double i= 1; i &lt; (N_strobo)/2.+0.5; i = i+ 1){\n\t\t\tsleep((DELTA_t -delta_t) us);\n\t\t\tturn(beam2, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(beam2, 0);\n\t\t}\n\t\tturn(beam1, 0);\n\t}\n\n\tif (sel==2){\n\n\t\tset_dds(dds_strobo,frequency, phase, pwr);\n\t\tturn(beam1, 1);\n\n\t\tsleep((t_ramsey + (N_max - N_strobo)/2 * DELTA_t) us);\n\n\t\t\n\t\tfor(double i2= 1; i2 &lt; (N_strobo)/2.+0.5; i2 = i2+ 1){\n\t\t\tsleep((DELTA_t -delta_t) us);\n\t\t\tturn(beam2, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(beam2, 0);\n\t\t}\n\t\tturn(beam1, 0);\n\t}\n\n\tif (sel==0){\n\n\t\tset_dds(dds_mw,frequency, phase, 0.54);\n\n\t\tsleep((t_ramsey + (N_max/2 * DELTA_t) - delta_t) us);\n\n\n\n\t\tfor(double i= 1; i &lt; 1.5; i = i + 1){\n\t\t\tturn(sw_mw, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(sw_mw, 0);\n\t\t}\n\t}\n\n\tsleep(1 us);\n\n}\n\n\nvoid active_phase_grating_Laser(beam1, beam2, sel, frequency, N_strobo, DELTA_t, delta_t, phase, pwr, N_max){\n\n\n\n\n\n\n\n\n\n\n\n\n\n\t\n\tif (sel==1){\n\n\t\tset_dds(dds_strobo,frequency, phase, pwr);\n\t\tturn(beam1, 1);\n\n\t\tsleep(((N_max - N_strobo)* DELTA_t) us);\n\n\t\t\n\t\tfor(double i= 1; i &lt; (N_strobo)+0.5; i = i+ 1){\n\t\t\tsleep((DELTA_t -delta_t) us);\n\t\t\tturn(beam2, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(beam2, 0);\n\t\t}\n\t\tturn(beam1, 0);\n\t}\n\n\tif (sel==2){\n\n\t\tset_dds(dds_strobo,frequency, phase, pwr);\n\t\tturn(beam1, 1);\n\n\t\tsleep(((N_max - N_strobo) * DELTA_t) us);\n\n\t\t\n\t\tfor(double i2= 1; i2 &lt; (N_strobo)+0.5; i2 = i2+ 1){\n\t\t\tsleep((DELTA_t -delta_t) us);\n\t\t\tturn(beam2, 1);\n\t\t\tsleep(delta_t us);\n\t\t\tturn(beam2, 0);\n\t\t}\n\t\tturn(beam1, 0);\n\t}\n\n\tsleep(1 us);\n\n}\nvoid sb_cool_cycle(fr_rsb1_c, t_oc_c, conf){\n\tif(conf == 1){\n\t\trtpulse(conf, fr_rsb1_c, t_oc_c, 0., pwr_b1_sbc, fr_r2, pwr_r2_sbc);\n\t}\n\tif(conf == 2){\n\t\trtpulse(conf, fr_rsb1_c, t_oc_c, 0., pwr_b1_sbc, fr_r2, pwr_r2_sbc);\n\t}\n\tif(conf == 5){\n\t\trtpulse(conf, fr_rsb1_c, t_oc_c, 0.,pwr_b3_sbc,fr_r2,pwr_r1_sbc);\n\t}\n\tif(conf == 57){\n\t\trtpulse(conf, fr_rsb1_c, t_oc_c, 0.,pwr_r1_L_sbc,fr_r2,pwr_b3_sbc);\n\t}\n\tturn(rd, 1);\n\tturn(rp, 1);\n\tsleep(t_rd_sbc us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n}\n\nvoid sb_cool_block(cool_Q, fr_raman_carrier, fr_raman_mode, fr_mode, t_pulse, beamconf, calc_Q){\n\tif(cool_Q == 1){\n\t\tif(t_pulse &gt; 0 ){\n\t\t\tif(calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_raman_carrier - fr_mode, t_pulse, beamconf);\n\t\t\t}\n\t\t\tif(calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_raman_mode, t_pulse, beamconf);\n\t\t\t}\n\t\t}\n\t\tif(t_pulse == 0){\n\t\t\tsleep(0);\n\t\t}\n\t}\n\tsleep(0);\n}\n\nvoid old_sb_cooling(){\nif(A_sbc == 1){\n\tloop(no_sbc_outer){\n\tloop(no_sbc_inner_3R){\n\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_lf_3R,t_sbc_lf_3, conf_lf_rsb);\n\t\t}\n\n\n\n\n\n\n\t\tsleep(0);\n\t}\n\tloop(no_sbc_inner_2R){\n\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_lf_2R,t_sbc_lf_2, conf_lf_rsb);\n\t\t}\n\t\tif(cool_mode_mf == 1){\n\t\t\tsb_cool_cycle(fr_mf_2R,t_sbc_mf_2, conf_mf_rsb);\n\t\t}\n\t\tif(cool_mode_hf == 1){\n\t\t\tsb_cool_cycle(fr_hf_2R,t_sbc_hf_2, conf_hf_rsb);\n\t\t}\n\t\tsleep(0);\n\t}\n\tloop(no_sbc_inner_1R){\n\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_lf_1R,t_sbc_lf_1, conf_lf_rsb);\n\t\t}\n\t\tif(cool_mode_mf == 1){\n\t\t\tsb_cool_cycle(fr_mf_1R,t_sbc_mf_1, conf_mf_rsb);\n\t\t}\n\t\tif(cool_mode_hf == 1){\n\n\t\t\tsb_cool_cycle(fr_hf_1R,t_sbc_hf_1, conf_hf_rsb);\n\t\t}\n\t\tsleep(0);\n\t}\n\tturn(rd, 1);\n\tturn(rp, 1);\n\tsleep((3*t_rd_sbc) us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n\t}\n}\nsleep(0);\n}\n\n\nvoid new_sb_cooling(){\nif(A_sbc == 1){\n\tloop(3){\n\t\tloop(10){\n\t\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_oc - 1.732*2*fr_lf,t_sbc_lf_str_2, conf_lf_rsb);\n\t\t\t}\n\t\t}\n\t\tloop(10){\n\t\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_oc - 2*fr_lf,t_sbc_lf_2, conf_lf_rsb);\n\t\t\t}\n\t\t}\n\t\tloop(15){\n\t\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_oc - 1.732*1*fr_lf,t_sbc_lf_str_1, conf_lf_rsb);\n\t\t\t}\n\t\t}\n\t\tloop(15){\n\t\t\tif(cool_mode_lf == 1){\n\t\t\tsb_cool_cycle(fr_oc - 1*fr_lf,t_sbc_lf_1, conf_lf_rsb);\n\t\t\t}\n\t\t}\n\tturn(rd, 1);\n\tturn(rp, 1);\n\tsleep((3*t_rd_sbc) us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n\t}\n}\nsleep(0);\n}\n\n\nvoid working_sb_cooling(){\nif(A_sbc == 1){\n\n\tloop(no_sbc_outer){\n\t\tloop(no_sbc_inner_2R){\n\t\t\tif(cool_mode_hf == 1){\n\n\t\t\t\tif(cool_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_roc - (2*fr_hf),sbc_fact_t*t_sbc_hf_2, conf_hf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t\tif(cool_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_hf_2R,sbc_fact_t*t_sbc_hf_2, conf_hf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(cool_RCKhf == 1){\n\n\t\t\t\tif(cool_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_roc - (2*fr_RCKh),sbc_fact_t*t_sbc_RCKh_2, conf_hf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t\tif(cool_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_RCKh_2R,sbc_fact_t*t_sbc_RCKh_2R, conf_hf_rsb);\t\t\t\t\n\t\t\t\t}// bis hier ok\n\t\t\t}\n\t\t\tif(cool_mode_mf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (2*fr_mf),sbc_fact_t*t_sbc_mf_2, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKmf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (2*fr_RCKm),sbc_fact_t*t_sbc_RCKm_2R, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_lf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (2*fr_lf),sbc_fact_t*t_sbc_lf_2, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_2R,sbc_fact_t*t_sbc_lf_2, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(cool_RCKlf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (2*1.732*fr_lf),sbc_fact_t*t_sbc_lf_str_2, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_str_2R,sbc_fact_t*t_sbc_lf_str_2, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tloop(no_sbc_inner_1R){\n\t\t\tif(cool_mode_hf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_hf),sbc_fact_t*t_sbc_hf_1, conf_hf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKhf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_RCKh),sbc_fact_t*t_sbc_RCKh_1R, conf_hf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_mf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_mf),sbc_fact_t*t_sbc_mf_1, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKmf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_RCKm),sbc_fact_t*t_sbc_RCKm_1R, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_lf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (1*fr_lf),sbc_fact_t*t_sbc_lf_1, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_1R,sbc_fact_t*t_sbc_lf_1, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(cool_RCKlf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (1*1.732*fr_lf),sbc_fact_t*t_sbc_lf_str_1, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_str_1R,sbc_fact_t*t_sbc_lf_str_1, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\tturn(rd, 1);\n\tturn(rp, 1);\n\tsleep((3*t_rd_sbc) us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n\t}\n\n\tloop(no_sbc_outer){\n\t\tloop(no_sbc_inner_2R){\n\t\t\tif(cool_mode_hf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (2*fr_hf),t_sbc_hf_2, conf_hf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKhf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (2*fr_RCKh),t_sbc_RCKh_2R, conf_hf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_mf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (2*fr_mf),t_sbc_mf_2, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKmf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (2*fr_RCKm),t_sbc_RCKm_2R, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_lf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (2*fr_lf),t_sbc_lf_2, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_2R,t_sbc_lf_2, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(cool_RCKlf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (2*1.732*fr_lf),t_sbc_lf_str_2, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_str_2R,t_sbc_lf_str_2, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tloop(no_sbc_inner_1R){\n\t\t\tif(cool_mode_hf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_hf),t_sbc_hf_1, conf_hf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKhf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_RCKh),t_sbc_RCKh_1R, conf_hf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_mf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_mf),t_sbc_mf_1, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_RCKmf == 1){\n\t\t\tsb_cool_cycle(fr_roc - (1*fr_RCKm),t_sbc_RCKm_1R, conf_mf_rsb);\n\t\t\t}\n\t\t\tif(cool_mode_lf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (1*fr_lf),t_sbc_lf_1, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_1R,t_sbc_lf_1, conf_lf_rsb);\t\t\t\t\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(cool_RCKlf == 1){\n\t\t\t\tif(cool_lf_calc_Q == 1){\n\t\t\t\tsb_cool_cycle(fr_oc - (1*1.732*fr_lf),t_sbc_lf_str_1, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t\tif(cool_lf_calc_Q == 0){\n\t\t\t\tsb_cool_cycle(fr_lf_str_1R,t_sbc_lf_str_1, conf_lf_rsb);\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\tturn(rd, 1);\n\tturn(rp, 1);\n\tsleep((3*t_rd_sbc) us);\n\tturn(rd, 0);\n\tturn(rp, 0);\n\t}\n}\nsleep(0);\n}\n\nvoid sb_cooling(){\n\nif(A_sbc == 1){\n\tif(conf_rsb==5){\n\n\n\n\t\tloop(no_sbc_outer){\n\n\n\n\n\n\n\n\n\t\t\tloop(no_sbc_inner_2R){\n\t\t\t\tif(skip_hf_2R_AC==0){\n\t\t\t\t\tsb_cool_block(cool_mode_hf,fr_roc, fr_sbc_hf_2_AC, 2*fr_hf, sbc_fact_t*t_sbc_hf_2_AC, 5, cool_calc_Q);\t\n\t\t\t\t\tsb_cool_block(cool_RCKhf,fr_roc, fr_sbc_RCKh_2_AC, 2*fr_RCKh, sbc_fact_t*t_sbc_RCKh_2_AC, 5, cool_calc_Q);\n\t\t\t\t}\n\t\t\t\tsb_cool_block(cool_mode_mf,fr_roc, fr_sbc_mf_2_AC, 2*fr_mf, sbc_fact_t*t_sbc_mf_2_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_RCKmf,fr_roc, fr_sbc_RCKm_2_AC, 2*fr_RCKm, sbc_fact_t*t_sbc_RCKm_2_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_mode_lf,fr_oc, fr_sbc_lf_2_AC, 2*fr_lf, sbc_fact_t*t_sbc_lf_2_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_RCKlf,fr_oc, fr_sbc_STR_2_AC, 2*fr_lf_str, sbc_fact_t*t_sbc_STR_2_AC, 5, cool_calc_Q);\n\t\t\t}\n\t\t\tloop(no_sbc_inner_1R){\n\t\t\t\tsb_cool_block(cool_mode_hf,fr_roc, fr_sbc_hf_1_AC, fr_hf, sbc_fact_t*t_sbc_hf_1_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_RCKhf,fr_roc, fr_sbc_RCKh_1_AC, fr_RCKh, sbc_fact_t*t_sbc_RCKh_1_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_mode_mf,fr_roc, fr_sbc_mf_1_AC, fr_mf, sbc_fact_t*t_sbc_mf_1_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_RCKmf,fr_roc, fr_sbc_RCKm_1_AC, fr_RCKm, sbc_fact_t*t_sbc_RCKm_1_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_mode_lf,fr_oc, fr_sbc_lf_1_AC, fr_lf, sbc_fact_t*t_sbc_lf_1_AC, 5, cool_calc_Q);\n\t\t\t\tsb_cool_block(cool_RCKlf,fr_oc, fr_sbc_STR_1_AC, fr_lf_str, sbc_fact_t*t_sbc_STR_1_AC, 5, cool_calc_Q);\n\t\t\t}\n\t\tturn(rd, 1);\n\t\tturn(rp, 1);\n\t\tsleep((3*t_rd_sbc) us);\n\t\tturn(rd, 0);\n\t\tturn(rp, 0);\n\t\t}\n\n\t\tloop(no_sbc_ou